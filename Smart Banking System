// ============================================================
// SECTION 3 – TRANSACTION CLASS  (bank.transactions)
// ============================================================

class Transaction implements Serializable {
    private String transactionId;
    private String type;          // DEPOSIT / WITHDRAW / TRANSFER
    private double amount;
    private Date timestamp;
    private String sourceAccount;
    private String targetAccount;
    private String status;        // SUCCESS / FAILED / FLAGGED

    public Transaction(String type, double amount,
                       String sourceAccount, String targetAccount) {
        this.transactionId = "TXN" + System.currentTimeMillis();
        this.type          = type;
        this.amount        = amount;
        this.sourceAccount = sourceAccount;
        this.targetAccount = targetAccount;
        this.timestamp     = new Date();
        this.status        = "SUCCESS";
    }

    // getters
    public String getTransactionId() { return transactionId; }
    public String getType()          { return type; }
    public double getAmount()        { return amount; }
    public Date   getTimestamp()     { return timestamp; }
    public String getStatus()        { return status; }
    public String getSourceAccount() { return sourceAccount; }

    public void setStatus(String status) { this.status = status; }

    @Override
    public String toString() {
        SimpleDateFormat sdf = new SimpleDateFormat("dd-MM-yyyy HH:mm:ss");
        return String.format("[%s] %s | Amount: %.2f | From: %s | To: %s | Status: %s | Time: %s",
                transactionId, type, amount, sourceAccount,
                targetAccount == null ? "N/A" : targetAccount,
                status, sdf.format(timestamp));
    }
}
// ============================================================
// SECTION 4 – BANK ACCOUNT  (bank.accounts)
// ============================================================
abstract class BankAccount implements TransactionOperations, SecureAccount, Serializable {
    protected String accountNumber;
    protected double balance;
    protected String owner;          // customer id
    protected boolean isFrozen;
    protected List<Transaction> transactions;

    public BankAccount(String accountNumber, String owner, double initialBalance) {
        this.accountNumber = accountNumber;
        this.owner         = owner;
        this.balance       = initialBalance;
        this.isFrozen      = false;
        this.transactions  = new ArrayList<>();
    }
    // ---------- TransactionOperations ----------
    @Override
    public void deposit(double amount) throws BankException {
        if (isFrozen)
            throw new BankException("Account is frozen. Cannot deposit.");
        if (amount <= 0)
            throw new BankException("Deposit amount must be positive.");

        balance += amount;
        Transaction t = new Transaction("DEPOSIT", amount, accountNumber, null);
        transactions.add(t);
        System.out.println("Deposited: " + amount);
    }
    @Override
    public void withdraw(double amount) throws BankException {
        if (isFrozen)
            throw new BankException("Account is frozen. Cannot withdraw.");
        if (amount <= 0)
            throw new BankException("Withdrawal amount must be positive.");
        if (amount > balance)
            throw new BankException("Insufficient balance.");

        balance -= amount;
        Transaction t = new Transaction("WITHDRAW", amount, accountNumber, null);
        transactions.add(t);
        System.out.println("Withdrawn: " + amount);
    }
    @Override
    public void transfer(BankAccount target, double amount) throws BankException {
        if (isFrozen)
            throw new BankException("Account is frozen. Cannot transfer.");
        if (amount <= 0)
            throw new BankException("Transfer amount must be positive.");
        if (amount > balance)
            throw new BankException("Insufficient balance for transfer.");

        balance -= amount;
        target.balance += amount;
        Transaction t = new Transaction("TRANSFER", amount, accountNumber, target.accountNumber);
        transactions.add(t);
        target.transactions.add(t);
        System.out.println("Transferred " + amount + " to " + target.accountNumber);
    }
